[daemon]
socket_path = "~/.local/run/worktree-sync.sock"
state_path = "~/.local/state/worktree-sync/state.json"
git_timeout_ms = 500
integration_timeout_ms = 500
neutral_color = "#1f1f1f"

[colors]
# Optional override palette. If empty, built-in 24-color palette is used.
palette = []
strict_palette = false

[integrations.ghostty]
enabled = true
# Used only if tab-specific TTY updates fail.
global_fallback_path = "~/.config/ghostty/worktree-sync-global.conf"
# Reserved for future file-based override mode.
overrides_dir = "~/.config/ghostty/worktree-sync.d"

[integrations.cursor]
enabled = true
